# Harbormaster serving plane settings (env prefix HM_). Copy to serving/.env for local runs.

HM_ENV=dev

# HITL queue backend. Leave empty to use the in-memory backend (default; tests/CI).
# Set a DSN to use the real Postgres backend (Phase 1.2 schema is created on connect).
# HM_PG_DSN=postgresql://harbormaster:harbormaster@localhost:5432/harbormaster

# Kinematics (mirrors GeoTrace GT_VESSEL_V_MAX_KTS). 25 kts = 12.8611 m/s.
HM_VESSEL_V_MAX_KTS=25

# Scoring / HITL routing
HM_HITL_CONFIDENCE_THRESHOLD=0.7
HM_ANOMALY_HITL_THRESHOLD=0.6

# Gap detection
HM_COVERAGE_THRESHOLD_S=600
HM_GAP_SATURATION_S=7200

# Speed scoring vs corrupt-data rejection
HM_SPEED_SATURATION_MULT=3
HM_CORRUPT_REJECT_FACTOR=12

# Corridor (GTRA static sea-lane graph)
HM_OFF_CORRIDOR_THRESHOLD_M=2000
HM_CORRIDOR_SATURATION_M=6000
