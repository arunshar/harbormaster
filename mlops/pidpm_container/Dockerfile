# Illustrative, NOT built or run in this repo (Phase 3, gate 3.6).
#
# Wraps pi-grpo's frozen PiDpmScorer.log_prob(trajectory) -> float contract
# (app/components/pidpm_scorer.py in the separate pi-grpo repo) as a
# SageMaker inference container. SageMaker async inference containers use
# the SAME real-time /ping + /invocations contract as synchronous endpoints;
# "async" is SageMaker's own orchestration (queue via S3, not synchronous
# HTTP), invisible to the container itself.
#
# This Dockerfile is not buildable as-is here: pi-grpo's scorer code lives in
# a separate repo (~/paper-work/pi-grpo on the MSI mirror, see
# docs/phases/PHASE_3.md's reuse anchors) and is not vendored into
# harbormaster. The real build step (Arun-run, at demo-apply time) checks
# out pi-grpo at a pinned commit into build context alongside this
# Dockerfile, matching the "build + push, Arun-run" pattern already used for
# the CDC connect/consumer images.

FROM python:3.11-slim

WORKDIR /opt/pidpm

# Real build step: `git clone --depth 1 --branch <pinned-sha> <pi-grpo-repo> pi_grpo_src`
# into the build context before `docker build`, so this COPY has something
# to copy. Left as an explicit, documented manual step rather than a
# submodule, since pi-grpo is a separate, independently-versioned repo.
COPY pi_grpo_src/app/components/pidpm /opt/pidpm/pidpm
COPY pi_grpo_src/app/components/pidpm/requirements.txt /opt/pidpm/requirements.txt
COPY server.py /opt/pidpm/server.py

RUN pip install --no-cache-dir -r requirements.txt "flask>=3.0" "gunicorn>=22.0"

ENV MODEL_PATH=/opt/ml/model/model.pt
EXPOSE 8080

# SageMaker's contract: /ping (health) and /invocations (score) on :8080.
CMD ["gunicorn", "--bind", "0.0.0.0:8080", "--workers", "1", "server:app"]
