{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "AllowAccountIdentitiesToAssumeWithMFA",
      "Effect": "Allow",
      "Principal": { "AWS": "arn:aws:iam::__ACCOUNT_ID__:root" },
      "Action": "sts:AssumeRole",
      "Condition": { "Bool": { "aws:MultiFactorAuthPresent": "true" } }
    }
  ]
}
