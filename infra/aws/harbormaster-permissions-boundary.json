{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "AllowHarbormasterServiceCeiling",
      "Effect": "Allow",
      "Action": [
        "s3:*",
        "dynamodb:*",
        "kinesis:*",
        "firehose:*",
        "glue:*",
        "athena:*",
        "logs:*",
        "cloudwatch:*",
        "sns:*",
        "sqs:*",
        "ecs:*",
        "eks:*",
        "ec2:*",
        "ecr:*",
        "elasticloadbalancing:*",
        "application-autoscaling:*",
        "autoscaling:*",
        "servicediscovery:*",
        "kms:*",
        "secretsmanager:*",
        "ssm:*",
        "budgets:*",
        "ce:*",
        "kinesisanalytics:*",
        "kafka:*",
        "kafka-cluster:*",
        "elasticmapreduce:*",
        "emr-serverless:*",
        "sagemaker:*",
        "scheduler:*",
        "events:*",
        "lambda:*",
        "xray:*",
        "execute-api:Invoke",
        "ssmmessages:*"
      ],
      "Resource": "*"
    },
    {
      "Sid": "PlatformManageBoundedRoles",
      "Effect": "Allow",
      "Action": [
        "iam:CreateRole",
        "iam:AttachRolePolicy",
        "iam:PutRolePolicy",
        "iam:DetachRolePolicy",
        "iam:DeleteRolePolicy"
      ],
      "Resource": "arn:aws:iam::*:role/harbormaster-*",
      "Condition": {
        "ArnLike": {
          "aws:PrincipalArn": "arn:aws:iam::*:role/harbormaster-platform",
          "iam:PermissionsBoundary": "arn:aws:iam::*:policy/harbormaster-permissions-boundary"
        }
      }
    },
    {
      "Sid": "PlatformManageRoles",
      "Effect": "Allow",
      "Action": [
        "iam:DeleteRole",
        "iam:GetRole",
        "iam:UpdateRole",
        "iam:ListAttachedRolePolicies",
        "iam:GetRolePolicy",
        "iam:ListRolePolicies",
        "iam:TagRole",
        "iam:UntagRole",
        "iam:UpdateAssumeRolePolicy"
      ],
      "Resource": "arn:aws:iam::*:role/harbormaster-*",
      "Condition": {
        "ArnLike": {
          "aws:PrincipalArn": "arn:aws:iam::*:role/harbormaster-platform"
        }
      }
    },
    {
      "Sid": "PlatformPassRolesToServices",
      "Effect": "Allow",
      "Action": "iam:PassRole",
      "Resource": "arn:aws:iam::*:role/harbormaster-*",
      "Condition": {
        "ArnLike": {
          "aws:PrincipalArn": "arn:aws:iam::*:role/harbormaster-platform"
        },
        "StringEquals": {
          "iam:PassedToService": [
            "ecs-tasks.amazonaws.com",
            "ecs.amazonaws.com",
            "firehose.amazonaws.com",
            "kinesisanalytics.amazonaws.com",
            "eks.amazonaws.com",
            "ec2.amazonaws.com",
            "elasticmapreduce.amazonaws.com",
            "sagemaker.amazonaws.com",
            "scheduler.amazonaws.com",
            "events.amazonaws.com",
            "lambda.amazonaws.com",
            "application-autoscaling.amazonaws.com"
          ]
        }
      }
    },
    {
      "Sid": "PlatformManageEksOidc",
      "Effect": "Allow",
      "Action": [
        "iam:CreateOpenIDConnectProvider",
        "iam:DeleteOpenIDConnectProvider",
        "iam:GetOpenIDConnectProvider",
        "iam:UpdateOpenIDConnectProviderThumbprint",
        "iam:AddClientIDToOpenIDConnectProvider",
        "iam:RemoveClientIDFromOpenIDConnectProvider",
        "iam:TagOpenIDConnectProvider",
        "iam:UntagOpenIDConnectProvider",
        "iam:ListOpenIDConnectProviderTags"
      ],
      "Resource": "arn:aws:iam::*:oidc-provider/oidc.eks.us-east-1.amazonaws.com/id/*",
      "Condition": {
        "ArnLike": {
          "aws:PrincipalArn": "arn:aws:iam::*:role/harbormaster-platform"
        }
      }
    },
    {
      "Sid": "PlatformListEksOidc",
      "Effect": "Allow",
      "Action": "iam:ListOpenIDConnectProviders",
      "Resource": "*",
      "Condition": {
        "ArnLike": {
          "aws:PrincipalArn": "arn:aws:iam::*:role/harbormaster-platform"
        }
      }
    },
    {
      "Sid": "PlatformManagePolicies",
      "Effect": "Allow",
      "Action": [
        "iam:CreatePolicy",
        "iam:DeletePolicy",
        "iam:GetPolicy",
        "iam:GetPolicyVersion",
        "iam:CreatePolicyVersion",
        "iam:DeletePolicyVersion",
        "iam:ListPolicyVersions",
        "iam:TagPolicy",
        "iam:UntagPolicy"
      ],
      "Resource": "arn:aws:iam::*:policy/harbormaster-*",
      "Condition": {
        "ArnLike": {
          "aws:PrincipalArn": "arn:aws:iam::*:role/harbormaster-platform"
        }
      }
    },
    {
      "Sid": "PlatformManageInstanceProfiles",
      "Effect": "Allow",
      "Action": [
        "iam:GetInstanceProfile",
        "iam:CreateInstanceProfile",
        "iam:DeleteInstanceProfile",
        "iam:AddRoleToInstanceProfile",
        "iam:RemoveRoleFromInstanceProfile",
        "iam:ListInstanceProfilesForRole"
      ],
      "Resource": [
        "arn:aws:iam::*:instance-profile/harbormaster-*",
        "arn:aws:iam::*:role/harbormaster-*"
      ],
      "Condition": {
        "ArnLike": {
          "aws:PrincipalArn": "arn:aws:iam::*:role/harbormaster-platform"
        }
      }
    },
    {
      "Sid": "PlatformCreateServiceLinkedRoles",
      "Effect": "Allow",
      "Action": "iam:CreateServiceLinkedRole",
      "Resource": "arn:aws:iam::*:role/aws-service-role/*",
      "Condition": {
        "ArnLike": {
          "aws:PrincipalArn": "arn:aws:iam::*:role/harbormaster-platform"
        },
        "StringEquals": {
          "iam:AWSServiceName": [
            "ecs.amazonaws.com",
            "elasticloadbalancing.amazonaws.com",
            "application-autoscaling.amazonaws.com",
            "autoscaling.amazonaws.com",
            "eks.amazonaws.com",
            "eks-nodegroup.amazonaws.com",
            "spot.amazonaws.com",
            "kinesisanalytics.amazonaws.com",
            "sagemaker.amazonaws.com"
          ]
        }
      }
    },
    {
      "Sid": "AllowBudgetActionSpendFreeze",
      "Effect": "Allow",
      "Action": [
        "iam:AttachRolePolicy",
        "iam:DetachRolePolicy"
      ],
      "Resource": "arn:aws:iam::*:role/harbormaster-platform",
      "Condition": {
        "ArnLike": {
          "aws:PrincipalArn": [
            "arn:aws:iam::*:role/harbormaster-base-budget-action",
            "arn:aws:iam::*:role/harbormaster-demo-budget-action"
          ],
          "iam:PolicyARN": [
            "arn:aws:iam::*:policy/harbormaster-base-spend-freeze",
            "arn:aws:iam::*:policy/harbormaster-demo-spend-freeze"
          ]
        }
      }
    },
    {
      "Sid": "DenyPlatformSelfMutation",
      "Effect": "Deny",
      "Action": [
        "iam:PutRolePolicy",
        "iam:DeleteRolePolicy",
        "iam:UpdateAssumeRolePolicy",
        "iam:DeleteRole",
        "iam:UpdateRole",
        "iam:AttachRolePolicy",
        "iam:DetachRolePolicy"
      ],
      "Resource": "arn:aws:iam::*:role/harbormaster-platform",
      "Condition": {
        "ArnLike": {
          "aws:PrincipalArn": "arn:aws:iam::*:role/harbormaster-platform"
        }
      }
    },
    {
      "Sid": "DenyBoundaryPolicyMutation",
      "Effect": "Deny",
      "Action": [
        "iam:CreatePolicyVersion",
        "iam:DeletePolicyVersion",
        "iam:SetDefaultPolicyVersion",
        "iam:DeletePolicy"
      ],
      "Resource": "arn:aws:iam::*:policy/harbormaster-permissions-boundary"
    },
    {
      "Sid": "DenyAllIamWriteEscalation",
      "Effect": "Deny",
      "Action": [
        "iam:CreateRole",
        "iam:DeleteRole",
        "iam:UpdateRole",
        "iam:CreateUser",
        "iam:DeleteUser",
        "iam:CreateGroup",
        "iam:CreateLoginProfile",
        "iam:UpdateLoginProfile",
        "iam:CreateAccessKey",
        "iam:PutRolePolicy",
        "iam:DeleteRolePolicy",
        "iam:AttachUserPolicy",
        "iam:PutUserPolicy",
        "iam:AttachGroupPolicy",
        "iam:PutGroupPolicy",
        "iam:CreatePolicy",
        "iam:CreatePolicyVersion",
        "iam:SetDefaultPolicyVersion",
        "iam:UpdateAssumeRolePolicy",
        "iam:CreateInstanceProfile",
        "iam:AddRoleToInstanceProfile",
        "iam:CreateServiceLinkedRole"
      ],
      "Resource": "*",
      "Condition": {
        "ArnNotLike": {
          "aws:PrincipalArn": "arn:aws:iam::*:role/harbormaster-platform"
        }
      }
    },
    {
      "Sid": "DenyBoundaryAlterationAndOrgEscape",
      "Effect": "Deny",
      "Action": [
        "iam:DeleteRolePermissionsBoundary",
        "iam:PutRolePermissionsBoundary",
        "iam:DeleteUserPermissionsBoundary",
        "iam:PutUserPermissionsBoundary",
        "organizations:*",
        "account:*"
      ],
      "Resource": "*"
    }
  ]
}
